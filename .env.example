# Supabase – Projekt: byeftmpqmovxikdfajyj
# Dashboard: https://supabase.com/dashboard/project/byeftmpqmovxikdfajyj

NEXT_PUBLIC_SUPABASE_URL=https://byeftmpqmovxikdfajyj.supabase.co
# Aus Supabase → Project Settings → API (anon key oder publishable key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternativ (neues Supabase-Format):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Lokal: Session pooler Port 5432
DATABASE_URL=postgresql://postgres.byeftmpqmovxikdfajyj:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require

# Vercel (Production): Transaction pooler Port 6543 + pgbouncer (oder gleiche URL — Code wechselt auf 6543 automatisch)
# DATABASE_URL=postgresql://postgres.byeftmpqmovxikdfajyj:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Stripe (aktuell einzige Zahlungsmethode im Checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# PayPal im Checkout (standard: aus). Nur bei true + Keys unten wieder aktivieren
# NEXT_PUBLIC_PAYPAL_ENABLED=true
# NEXT_PUBLIC_PAYPAL_PAYMENT_LINK=https://paypal.me/SimexMafia

# Öffentliche Site-URL (E-Mails, SEO, Redirects)
NEXT_PUBLIC_SITE_URL=https://simexmafia.vercel.app

# Support-E-Mail (überall auf der Website)
NEXT_PUBLIC_CONTACT_EMAIL=simexmafia.support@gmail.com

# Google OAuth (optional)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Resend (E-Mails — Pflicht für Bestätigungscode bei Registrierung)
RESEND_API_KEY=re_...
EMAIL_VERIFY_SECRET=change-me-to-a-long-random-string
PASSWORD_RESET_SECRET=change-me-to-another-long-random-string
# Ohne verifizierte Domain: SimexMafia <onboarding@resend.dev>
# Mit Domain in Resend: SimexMafia <noreply@deine-domain.de>
RESEND_FROM_EMAIL=SimexMafia <onboarding@resend.dev>

# HMAC-Session-Cookie (sm_session) — Pflicht in Production
SESSION_SECRET=change-me-to-a-very-long-random-string-min-32-chars

# Cloudflare Turnstile (Captcha bei Register / Forgot-Password / Contact)
# Leer lassen, um Captcha komplett zu deaktivieren (z. B. lokal)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# PayPal Server-Verifizierung (Orders v2 API)
# PAYPAL_MODE=live  → api-m.paypal.com, sonst Sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Auto-Lieferung "Simex Geheimer Discord-Server"
DISCORD_INVITE_URL=https://discord.gg/simex-geheim
